python"""
Constrained decoding for guaranteed valid JSON output.

The key idea: at each token generation step, we mask out (set to -inf)
all tokens that would break the expected structure, then let the model
pick from the remaining valid tokens.
"""

import json
import math
from typing import Any
import numpy as np
from llm_sdk import Small_LLM_Model


class VocabularyIndex:
    """
    Maps between token IDs and their string representations.
    
    This is crucial for constrained decoding — we need to know
    which token IDs correspond to which characters/strings so we
    can determine which tokens are valid at each generation step.
    """

    def __init__(self, model: Small_LLM_Model) -> None:
        """
        Load and index the vocabulary from the model's vocabulary JSON.

        Args:
            model: The LLM model instance.
        """
        vocab_path = model.get_path_to_vocabulary_json()
        
        with open(vocab_path, "r", encoding="utf-8") as f:
            raw_vocab: dict[str, str] = json.load(f)
        
        # raw_vocab maps token_id (as string) -> token_string
        # Example: {"42": "hello", "1337": " world", ...}
        self.id_to_token: dict[int, str] = {
            int(k): v for k, v in raw_vocab.items()
        }
        self.token_to_ids: dict[str, list[int]] = {}
        
        for token_id, token_str in self.id_to_token.items():
            if token_str not in self.token_to_ids:
                self.token_to_ids[token_str] = []
            self.token_to_ids[token_str].append(token_id)
        
        self.vocab_size = len(self.id_to_token)

    def get_ids_for_prefix(self, prefix: str) -> list[int]:
        """
        Get all token IDs whose string starts with the given prefix.
        
        Used when we need tokens that can continue a partial string.

        Args:
            prefix: The string prefix to match.

        Returns:
            List of matching token IDs.
        """
        return [
            token_id
            for token_str, ids in self.token_to_ids.items()
            for token_id in ids
            if token_str.startswith(prefix)
        ]

    def get_ids_for_exact(self, exact: str) -> list[int]:
        """
        Get token IDs that exactly match a string.

        Args:
            exact: The exact string to match.

        Returns:
            List of matching token IDs.
        """
        return self.token_to_ids.get(exact, [])


def generate_with_constraints(
    model: Small_LLM_Model,
    vocab: VocabularyIndex,
    prompt: str,
    valid_token_ids: list[int],
    max_new_tokens: int = 50
) -> str:
    """
    Generate text token-by-token, restricting to only valid token IDs.

    This is the core constrained decoding loop. At each step:
    1. Get logits for all tokens from the model
    2. Set all invalid tokens to -infinity
    3. Pick the highest-scoring valid token
    4. Add it to the sequence and repeat

    Args:
        model: The LLM model.
        vocab: The vocabulary index.
        prompt: Starting prompt text.
        valid_token_ids: The ONLY token IDs allowed to be generated.
        max_new_tokens: Safety limit on generation length.

    Returns:
        The generated text (not including the prompt).
    """
    import numpy as np  # noqa: PLC0415
    
    # Encode the prompt into token IDs
    input_ids: list[int] = model.encode(prompt)
    generated_ids: list[int] = []
    
    # Create a mask array: True means "block this token"
    # We'll set invalid tokens to -inf in logits
    all_token_ids = set(vocab.id_to_token.keys())
    valid_set = set(valid_token_ids)
    
    for _ in range(max_new_tokens):
        # Convert current sequence to tensor-like input
        current_ids = input_ids + generated_ids
        
        # Get logits from the model
        # Shape: [vocab_size] — one score per possible next token
        import torch  # noqa: PLC0415
        input_tensor = torch.tensor([current_ids])
        logits = model.get_logits_from_input_ids(input_tensor)
        
        # logits shape: [1, seq_len, vocab_size] — take last position
        next_token_logits = logits[0, -1, :].float().numpy()
        
        # Apply constraint: set all invalid token logits to -infinity
        for token_id in all_token_ids - valid_set:
            if token_id < len(next_token_logits):
                next_token_logits[token_id] = -math.inf
        
        # Pick the highest-scoring valid token (greedy decoding)
        next_token_id = int(np.argmax(next_token_logits))
        
        # Safety check: if no valid token found, stop
        if next_token_logits[next_token_id] == -math.inf:
            break
        
        generated_ids.append(next_token_id)
        
        # Stop if we've generated all we need (single selection case)
        break  # For function name selection, we generate one "chunk"
    
    return model.decode(generated_ids)
Ahora la parte más sofisticada — generar JSON completo token a token con un autómata de estados:
pythonclass JSONStateMachine:
    """
    A finite state machine that tracks what's valid in a JSON structure.
    
    States represent where we are in building the JSON:
    - OPEN: expecting opening {
    - KEY: building a key string
    - COLON: expecting :
    - VALUE_START: expecting start of a value
    - VALUE_STRING: building a string value
    - VALUE_NUMBER: building a number value  
    - COMMA_OR_CLOSE: expecting , or }
    - DONE: JSON complete
    
    At each state, only certain tokens are valid.
    This is what makes constrained decoding work for structured output.
    """
    
    def get_valid_tokens_for_state(
        self,
        state: str,
        partial_value: str,
        expected_keys: list[str],
        key_types: dict[str, str],
        current_key: str,
        vocab: VocabularyIndex
    ) -> list[int]:
        """Get valid token IDs for the current JSON construction state."""
        
        if state == "VALUE_NUMBER":
            # Only digits, minus, dot, and the closing tokens
            valid = []
            for token_str, ids in vocab.token_to_ids.items():
                # Allow digits, decimal point, minus at start
                if all(c in "0123456789.-" for c in token_str):
                    valid.extend(ids)
                # Allow closing after a complete number
                if token_str in [",", "}", " ", "\n"]:
                    valid.extend(ids)
            return valid
        
        # ... similar logic for other states
        return []

