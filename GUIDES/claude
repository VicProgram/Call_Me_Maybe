python"""
Main orchestrator that combines all components to resolve function calls.
"""

from typing import Any
from llm_sdk import Small_LLM_Model
from src.models import FunctionDefinition, FunctionCall
from src.constrained_decoder import VocabularyIndex
from src.prompt_builder import (
    build_function_selection_prompt,
    build_argument_extraction_prompt
)


class FunctionCaller:
    """
    Orchestrates LLM-based function selection and argument extraction.
    
    Two-phase approach:
    1. Use constrained decoding to select the function name
       (only valid function names are allowed as output)
    2. For each parameter, use constrained decoding to extract the value
       (only tokens valid for that parameter's type are allowed)
    """

    def __init__(self, model: Small_LLM_Model) -> None:
        """
        Initialize with a loaded LLM model.

        Args:
            model: Initialized Small_LLM_Model instance.
        """
        self.model = model
        self.vocab = VocabularyIndex(model)

    def select_function(
        self,
        prompt: str,
        functions: list[FunctionDefinition]
    ) -> FunctionDefinition:
        """
        Use the LLM to select which function to call.
        
        We constrain the output to only the valid function names.
        The model cannot output anything else.

        Args:
            prompt: Natural language request.
            functions: Available functions.

        Returns:
            The selected FunctionDefinition.
        """
        llm_prompt = build_function_selection_prompt(prompt, functions)
        
        # Build the set of valid token sequences — one per function name
        # We'll use a greedy approach: find which function name the model
        # assigns highest probability to after the prompt
        
        fn_names = [fn.name for fn in functions]
        fn_map = {fn.name: fn for fn in functions}
        
        # Score each function name by summing log-probs of its tokens
        import torch  # noqa: PLC0415
        import math
        
        input_ids = self.model.encode(llm_prompt)
        input_tensor = torch.tensor([input_ids])
        logits = self.model.get_logits_from_input_ids(input_tensor)
        next_logits = logits[0, -1, :].float()
        
        # Apply softmax to get probabilities
        import torch.nn.functional as F  # noqa: PLC0415
        probs = F.softmax(next_logits, dim=-1).numpy()
        
        # For each function name, score it by the probability of its
        # first token(s) appearing after the prompt
        best_fn = functions[0]
        best_score = -math.inf
        
        for fn_name in fn_names:
            # Encode the function name and check probability of first token
            fn_token_ids = self.model.encode(fn_name)
            if fn_token_ids and fn_token_ids[0] < len(probs):
                score = float(probs[fn_token_ids[0]])
                if score > best_score:
                    best_score = score
                    best_fn = fn_map[fn_name]
        
        return best_fn

    def extract_argument(
        self,
        prompt: str,
        fn_def: FunctionDefinition,
        param_name: str
    ) -> Any:
        """
        Extract a single argument value using constrained decoding.
        
        The constraint depends on the parameter type:
        - "number": only numeric tokens allowed
        - "string": any tokens until closing quote
        - "boolean": only "true" or "false"

        Args:
            prompt: Original natural language request.
            fn_def: The function definition.
            param_name: Parameter to extract.

        Returns:
            The extracted value with correct Python type.
        """
        param_type = fn_def.parameters[param_name].type
        llm_prompt = build_argument_extraction_prompt(prompt, fn_def, param_name)
        
        import torch  # noqa: PLC0415
        import numpy as np  # noqa: PLC0415
        import math
        
        input_ids = self.model.encode(llm_prompt)
        generated_text = ""
        
        for _ in range(30):  # Max 30 tokens for a value
            current_tensor = torch.tensor([input_ids + self.model.encode(generated_text)])
            logits = self.model.get_logits_from_input_ids(current_tensor)
            next_logits = logits[0, -1, :].float().numpy()
            
            # Get valid token IDs based on type and what we've built so far
            valid_ids = self._get_valid_token_ids(
                param_type, generated_text, self.vocab
            )
            
            # Mask invalid tokens
            mask = np.full(len(next_logits), -math.inf)
            for tid in valid_ids:
                if tid < len(next_logits):
                    mask[tid] = next_logits[tid]
            
            next_token_id = int(np.argmax(mask))
            
            if mask[next_token_id] == -math.inf:
                break
            
            next_token_str = self.vocab.id_to_token.get(next_token_id, "")
            
            # Check if this token ends the value
            if self._is_terminator(next_token_str, param_type, generated_text):
                break
            
            generated_text += next_token_str
            
            if self._is_complete(generated_text, param_type):
                break
        
        return self._cast_value(generated_text.strip(), param_type)

    def _get_valid_token_ids(
        self,
        param_type: str,
        current_text: str,
        vocab: VocabularyIndex
    ) -> list[int]:
        """Get valid token IDs for the current value being built."""
        valid = []
        
        if param_type == "number":
            for token_str, ids in vocab.token_to_ids.items():
                # Allow digits
                if token_str.lstrip("-").replace(".", "", 1).isdigit():
                    valid.extend(ids)
                # Allow negative sign at start
                if not current_text and token_str == "-":
                    valid.extend(ids)
                # Allow decimal point if not already present
                if "." not in current_text and token_str == ".":
                    valid.extend(ids)
        
        elif param_type == "string":
            # For strings, allow any token that doesn't break structure
            # In practice: allow all tokens except structural JSON chars
            for token_str, ids in vocab.token_to_ids.items():
                if token_str not in ["{", "}", "[", "]"]:
                    valid.extend(ids)
        
        elif param_type == "boolean":
            # Only "true" or "false" allowed
            for prefix in ["true", "false"]:
                remaining = prefix[len(current_text):]
                if prefix.startswith(current_text) and remaining:
                    valid.extend(vocab.get_ids_for_prefix(remaining[0]))
        
        return valid

    def _is_terminator(
        self, token_str: str, param_type: str, current_text: str
    ) -> bool:
        """Check if a token signals end of value."""
        if param_type == "number":
            return token_str in [",", "}", "\n", " "] and current_text
        if param_type == "string":
            return token_str in ["\n"] and current_text
        return False

    def _is_complete(self, text: str, param_type: str) -> bool:
        """Check if we have a complete value."""
        if param_type == "boolean":
            return text.strip() in ["true", "false"]
        return False

    def _cast_value(self, text: str, param_type: str) -> Any:
        """Cast the generated text to the correct Python type."""
        try:
            if param_type == "number":
                return float(text)
            if param_type == "integer":
                return int(text)
            if param_type == "boolean":
                return text.lower() == "true"
            return text  # string
        except (ValueError, TypeError):
            return text

    def resolve(
        self,
        prompt: str,
        functions: list[FunctionDefinition]
    ) -> FunctionCall:
        """
        Full pipeline: select function and extract all arguments.

        Args:
            prompt: Natural language request.
            functions: Available function definitions.

        Returns:
            Complete FunctionCall with name and all arguments.
        """
        fn_def = self.select_function(prompt, functions)
        
        args: dict[str, Any] = {}
        for param_name in fn_def.parameters:
            args[param_name] = self.extract_argument(prompt, fn_def, param_name)
        
        return FunctionCall(prompt=prompt, fn_name=fn_def.name, args=args)

