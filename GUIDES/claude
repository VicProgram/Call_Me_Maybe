python"""Entry point for the call me maybe function calling system."""

import argparse
import sys
from pathlib import Path
from llm_sdk import Small_LLM_Model
from src.file_handler import load_function_definitions, load_test_prompts, write_results
from src.function_caller import FunctionCaller


def parse_args() -> argparse.Namespace:
    """Parse command line arguments."""
    parser = argparse.ArgumentParser(description="LLM Function Calling System")
    parser.add_argument(
        "--input",
        type=Path,
        default=Path("data/input"),
        help="Input directory or file path"
    )
    parser.add_argument(
        "--output",
        type=Path,
        default=Path("data/output/function_calling_results.json"),
        help="Output file path"
    )
    return parser.parse_args()


def main() -> int:
    """Main entry point."""
    args = parse_args()
    
    # Resolve input paths
    if args.input.is_dir():
        definitions_path = args.input / "function_definitions.json"
        tests_path = args.input / "function_calling_tests.json"
    else:
        definitions_path = args.input
        tests_path = args.input
    
    # Load input files
    try:
        functions = load_function_definitions(definitions_path)
        prompts = load_test_prompts(tests_path)
    except (FileNotFoundError, ValueError) as e:
        print(f"Error loading input files: {e}", file=sys.stderr)
        return 1
    
    print(f"Loaded {len(functions)} functions and {len(prompts)} prompts")
    
    # Initialize model
    try:
        model = Small_LLM_Model()  # Loads Qwen3-0.6B by default
    except Exception as e:
        print(f"Error loading model: {e}", file=sys.stderr)
        return 1
    
    # Process each prompt
    caller = FunctionCaller(model)
    results = []
    
    for i, prompt in enumerate(prompts):
        print(f"Processing [{i+1}/{len(prompts)}]: {prompt[:60]}...")
        try:
            result = caller.resolve(prompt, functions)
            results.append(result)
            print(f"  → {result.fn_name}({result.args})")
        except Exception as e:
            print(f"  Error: {e}", file=sys.stderr)
    
    # Write output
    try:
        write_results(results, args.output)
        print(f"\nResults written to {args.output}")
    except Exception as e:
        print(f"Error writing output: {e}", file=sys.stderr)
        return 1
    
    return 0


if __name__ == "__main__":
    sys.exit(main())

