python"""Handles reading input files and writing output files."""

import json
from pathlib import Path
from typing import Any
from src.models import FunctionDefinition, FunctionCall


def load_json_file(path: Path) -> Any:
    """
    Load and parse a JSON file safely.

    Args:
        path: Path to the JSON file.

    Returns:
        Parsed JSON content.

    Raises:
        FileNotFoundError: If the file doesn't exist.
        ValueError: If the file contains invalid JSON.
    """
    if not path.exists():
        raise FileNotFoundError(f"Input file not found: {path}")
    
    try:
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f)
    except json.JSONDecodeError as e:
        raise ValueError(f"Invalid JSON in {path}: {e}") from e


def load_function_definitions(path: Path) -> list[FunctionDefinition]:
    """
    Load and validate function definitions from JSON.

    Args:
        path: Path to function_definitions.json

    Returns:
        List of validated FunctionDefinition objects.
    """
    raw = load_json_file(path)
    
    if not isinstance(raw, list):
        raise ValueError("function_definitions.json must contain a JSON array")
    
    definitions = []
    for i, item in enumerate(raw):
        try:
            definitions.append(FunctionDefinition(**item))
        except Exception as e:
            raise ValueError(f"Invalid function definition at index {i}: {e}") from e
    
    return definitions


def load_test_prompts(path: Path) -> list[str]:
    """
    Load test prompts from JSON.

    Args:
        path: Path to function_calling_tests.json

    Returns:
        List of prompt strings.
    """
    raw = load_json_file(path)
    
    if not isinstance(raw, list):
        raise ValueError("function_calling_tests.json must contain a JSON array")
    
    prompts = []
    for i, item in enumerate(raw):
        if not isinstance(item, str):
            raise ValueError(f"Prompt at index {i} must be a string, got {type(item)}")
        prompts.append(item)
    
    return prompts


def write_results(results: list[FunctionCall], output_path: Path) -> None:
    """
    Write function call results to JSON file.

    Args:
        results: List of FunctionCall objects to serialize.
        output_path: Destination file path.
    """
    output_path.parent.mkdir(parents=True, exist_ok=True)
    
    output_data = [result.model_dump() for result in results]
    
    with open(output_path, "w", encoding="utf-8") as f:
        json.dump(output_data, f, indent=2, ensure_ascii=False)

