python"""Builds prompts for the LLM to select functions and extract arguments."""

from src.models import FunctionDefinition


def build_function_selection_prompt(
    user_prompt: str,
    functions: list[FunctionDefinition]
) -> str:
    """
    Build a prompt asking the LLM to choose which function to call.

    The LLM only needs to output the function name — we'll use constrained
    decoding to force it to pick one of the valid names.

    Args:
        user_prompt: The natural language request.
        functions: Available function definitions.

    Returns:
        Complete prompt string.
    """
    fn_descriptions = "\n".join(
        f"- {fn.name}: {fn.description}"
        for fn in functions
    )
    
    return (
        f"You are a function calling assistant. "
        f"Given a user request, select the most appropriate function.\n\n"
        f"Available functions:\n{fn_descriptions}\n\n"
        f"User request: {user_prompt}\n\n"
        f"Function to call: "
    )


def build_argument_extraction_prompt(
    user_prompt: str,
    fn_def: FunctionDefinition,
    param_name: str
) -> str:
    """
    Build a prompt asking the LLM to extract a specific argument value.

    Args:
        user_prompt: The original natural language request.
        fn_def: The function being called.
        param_name: The specific parameter to extract.

    Returns:
        Complete prompt string.
    """
    param_type = fn_def.parameters[param_name].type
    
    return (
        f"Extract the value for parameter '{param_name}' "
        f"(type: {param_type}) from this request.\n\n"
        f"Function: {fn_def.name} - {fn_def.description}\n"
        f"Request: {user_prompt}\n\n"
        f"Value of '{param_name}': "
    )

